{
	order rate_limit before reverse_proxy
}

:443 {
	tls internal

	log {
		output file E:/go_ultra/logs/caddy.log {
			roll_size 10MiB
			roll_keep 7
		}
		format json
	}

	handle /api/* {
		rate_limit {
			zone api_zone {
				key {remote_host}
				events 60
				window 1m
			}
		}
		reverse_proxy localhost:8080
	}

	handle {
		root * E:/go_ultra/web/dist
		try_files {path} /index.html
		file_server
	}
}
